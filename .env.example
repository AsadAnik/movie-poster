# ──────────────────────────────────────────────────────────
#  FlickPicks – Environment Variables Template
#
#  1. Copy this file and rename it to .env.local
#  2. Fill in your own values below
#  3. Never commit your real .env.local to version control!
# ──────────────────────────────────────────────────────────

# OMDb API Key
#   Get your free key at: https://www.omdbapi.com/apikey.aspx
VITE_OMDB_API_KEY=your_omdb_api_key_here

# OMDb Base URL (no need to change this unless you use a proxy)
VITE_OMDB_BASE_URL=https://www.omdbapi.com/
